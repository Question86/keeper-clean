{
  "name": "keeper-cockpit-bridge",
  "displayName": "Keeper Cockpit Bridge",
  "description": "Bridge between Keeper Loop Cockpit and VS Code for file operations, terminal control, and loop state display",
  "version": "0.1.0",
  "publisher": "keeper-project",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "keeper.openFile",
        "title": "Keeper: Open File"
      },
      {
        "command": "keeper.runTerminalCommand",
        "title": "Keeper: Run Terminal Command"
      },
      {
        "command": "keeper.getSelection",
        "title": "Keeper: Get Current Selection"
      },
      {
        "command": "keeper.reconnect",
        "title": "Keeper: Reconnect to Cockpit"
      },
      {
        "command": "keeper.checkAgentCapability",
        "title": "Keeper: Check Agent Capability"
      },
      {
        "command": "keeper.spawnAgent",
        "title": "Keeper: Spawn AI Agent"
      },
      {
        "command": "keeper.showAgentOutput",
        "title": "Keeper: Show Agent Output"
      }
    ],
    "configuration": {
      "title": "Keeper Cockpit Bridge",
      "properties": {
        "keeper.cockpitUrl": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "URL of the Keeper Loop Cockpit server"
        },
        "keeper.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to cockpit on startup"
        },
        "keeper.pollInterval": {
          "type": "number",
          "default": 5000,
          "description": "Status polling interval in milliseconds"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.14.0"
  }
}
